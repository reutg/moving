# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# --- App ---
# Node runtime mode. Next.js sets this automatically; only override for tests.
# NODE_ENV=development

# --- Database ---
# Path to the SQLite file (relative to project root). The file is created on first run.
DATABASE_URL=file:./data/moving.db

# --- Logging ---
# One of: debug | info | warn | error
LOG_LEVEL=info
