# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# --- App ---
# Node runtime mode. Next.js sets this automatically; only override for tests.
# NODE_ENV=development

# Public app name (shown in UI).
NEXT_PUBLIC_APP_NAME=Moving on

# Public base URL of the deployed app, used to construct shareable links.
# In production set to e.g. https://moving.example.com (no trailing slash).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database ---
# libSQL/Turso connection string.
#   Local development: file:./data/moving.db (the file is created on first run).
#   Production (Turso): libsql://<your-db>-<org>.turso.io
DATABASE_URL=file:./data/moving.db

# Auth token issued by Turso (`turso db tokens create <name>`).
# Leave empty for local `file:` URLs.
DATABASE_AUTH_TOKEN=

# --- Logging ---
# One of: debug | info | warn | error
LOG_LEVEL=info

# --- Auth ---
# Random 32-byte secret used by Auth.js to sign session cookies and CSRF
# tokens. Generate with: openssl rand -base64 32. Rotating it logs everyone out.
AUTH_SECRET=

# Google OAuth client credentials from Google Cloud Console:
# https://console.cloud.google.com → APIs & Services → Credentials → OAuth client ID.
# Authorized redirect URI must include /api/auth/callback/google for every
# environment (e.g. http://localhost:3000/api/auth/callback/google).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- AI ---
# Google Gemini API key (https://aistudio.google.com/app/apikey).
GEMINI_KEY=
